{
  "name": "@ghostchain/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ghostchain": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@ghostchain/engine": "workspace:*",
    "@ghostchain/reporting": "workspace:*",
    "@ghostchain/shared": "workspace:*"
  }
}
